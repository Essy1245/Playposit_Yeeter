{
    "manifest_version": 3,
    "name": "Playposit Yeeter",
    "version": "1.0",
    "description": "Exposes default video controls and adds a fast-forward button for PlayPosit players.",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Yeet Playposit"
    },
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "*://*.instructure.com/*",
        "*://canvas.asu.edu/*",
        "file:///*"
    ]
}