{
    "manifest_version": 3,
    "name": "Playposit Yeeter",
    "version": "1.0",
    "description": "Exposes default video controls and adds a fast-forward button for PlayPosit players.",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.instructure.com/*",
                "*://canvas.asu.edu/*",
                "file:///*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_end",
            "all_frames": true
        }
    ],
    "host_permissions": [
        "*://*.instructure.com/*",
        "*://canvas.asu.edu/*",
        "file:///*"
    ]
}